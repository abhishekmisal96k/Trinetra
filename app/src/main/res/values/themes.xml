<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.Trinetra" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary colors -->
        <item name="colorPrimary">#0D47A1</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary (accent neon blue) -->
        <item name="colorSecondary">#00B0FF</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Background colors -->
        <item name="android:colorBackground">#000000</item>
        <item name="colorSurface">#121212</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>

        <!-- Text -->
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#B0B0B0</item>

    </style>

    <!-- App theme -->
    <style name="Theme.Trinetra" parent="Base.Theme.Trinetra" />

</resources>